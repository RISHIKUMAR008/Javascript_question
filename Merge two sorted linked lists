var mergeTwoLists = function(list1, list2) {
    let dummy = { next: null };
    let tail = dummy;

    while (list1 !== null && list2 !== null) {
        if (list1.data <= list2.data) {
            tail.next = list1;
            list1 = list1.next;
        } else {
            tail.next = list2;
            list2 = list2.next;
        }
        tail = tail.next;
    }

    // Attach remaining list
    tail.next = list1 !== null ? list1 : list2;

    return dummy.next;
};
